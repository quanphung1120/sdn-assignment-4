{
  "name": "api",
  "version": "0.0.0",
  "scripts": {
    "build": "shx rm -rf dist && npm run lint && tsc --project tsconfig.prod.json",
    "clean-install": "rm -rf ./node_modules && rm -r package-lock.json && npm i",
    "dev": "cross-env DOTENV_CONFIG_PATH=./config/.env.development nodemon --exec ts-node ./src/main --watch ./src --ext .ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "cross-env DOTENV_CONFIG_PATH=./config/.env.production node -r dotenv/config ./dist/main.js",
    "type-check": "tsc -b --noEmit"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "_moduleAliases": {
    "@src": "dist"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jet-env": "^1.1.6",
    "jet-logger": "^2.2.3",
    "jet-paths": "^3.1.1",
    "jet-validators": "^2.3.1",
    "jsonfile": "^6.2.1",
    "module-alias": "^2.3.4",
    "morgan": "^1.11.0",
    "tspo": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.41",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/find": "^0.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonfile": "^6.1.4",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "browser-sync": "^3.0.4",
    "concurrently": "^10.0.3",
    "delay-cli": "^3.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.1.0",
    "find": "^0.3.0",
    "fs-extra": "^11.3.5",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "shx": "^0.4.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
