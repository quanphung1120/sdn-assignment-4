# General
NODE_ENV=development

# Database configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=your_mongodb_password
MONGO_INITDB_DATABASE=assignment_db
MONGODB_URI=mongodb://admin:your_mongodb_password@localhost:27017/assignment_db?authSource=admin

# API configurations
API_PORT=3000
API_HOST=0.0.0.0
# Comma-separated list of allowed origins for CORS.
# In development, it allows localhost/Vite. In production, add your production domains.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80
JWT_SECRET=your_jwt_secret_key

# Web configurations
WEB_PORT=5173
VITE_API_URL=http://localhost:3000
